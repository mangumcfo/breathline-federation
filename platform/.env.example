# Breathline Agentic Platform — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.

# === Identity ===
# The principal_id is the canonical identity field per Constitution@A1 §1.
# It flows end-to-end through every layer. No hardcoded principals.
PRINCIPAL_ID=kmangum

# === Cylinder Auditor ===
# The platform's Auditor primitive calls operator-side seal.sh synchronously.
# This is the operator's hash-chained cylinder infrastructure.
CYLINDER_SEAL_SH=/home/kmangum/Tiger_1a/cylinders/seal.sh
CYLINDER_DIR=/home/kmangum/Tiger_1a/cylinders

# === Model Access ===
# Anthropic primary for kernel agents per default; provider-agnostic at role level.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Observability ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=breathline-agentic-platform-demo2
LANGSMITH_TRACING=false

# === Receipt Integration (SIX-SOV) ===
# Phase 2 (Cloudflare Tunnel) endpoint; until live, returns placeholder JSON.
SIX_SOV_VERIFY_ENDPOINT=https://six-sov.com/verify
SIX_SOV_DEGRADED_MODE_OK=true

# === Double-Anchoring ===
# Most recent Netlify deploy hash, embedded in cylinder seals (Direction A).
# Phase 2 build hook will populate this automatically.
NETLIFY_DEPLOY_HASH=

# === Cost Caps ===
# Override defaults from config/cost_caps.yaml
COST_CAP_PER_REQUEST_USD=1.00
COST_CAP_SESSION_TOTAL_USD=50.00
